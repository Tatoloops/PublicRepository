@startuml
skinparam ParticipantPadding 10
skinparam BoxPadding 10

title "El Motor MongoDB explicado"

actor "Usuario" as User
boundary "CLI (Terminal)" as CLI
participant "mongo_engine.py\n(El Chef)" as Chef
control "Plantilla JSON\n(El Menú/Pedido)" as Pedido
participant "PyMongo Driver\n(El Ayudante)" as Ayudante
database "MongoDB\n(La Despensa)" as Despensa

User -> CLI: Ejecuta comando\n(ej: python mongo_engine.py queries/q3.json)
CLI -> Chef: Inicia el script

group "1. Preparar el Pedido"
    Chef -> Pedido: Lee el archivo JSON
    activate Pedido
    Pedido --> Chef: Devuelve los datos (acción, filtros, etc.)
    deactivate Pedido
    Chef -> Chef: Analiza el pedido\n¿Qué quiere el usuario? (FIND, INSERT...)
end

group "2. Ir a la Despensa"
    Chef -> Ayudante: Conecta a la Despensa\n(DB: ecommerce, Coll: orders)
    activate Ayudante
    Ayudante -> Despensa: Establece conexión
    activate Despensa
    Despensa --> Ayudante: Conexión OK
    deactivate Despensa
    Ayudante --> Chef: Ayudante listo
    deactivate Ayudante
end

group "3. Ejecutar la Acción"
    note over Chef: En este ejemplo, el pedido dice FIND
    Chef -> Ayudante: "Ayudante, busca los registros que cumplan esto:"
    activate Ayudante
    Ayudante -> Despensa: Consulta la Despensa
    activate Despensa
    Despensa --> Ayudante: Devuelve los registros encontrados
    deactivate Despensa
    Ayudante --> Chef: Entrega los resultados
    deactivate Ayudante
end

group "4. Servir el Plato"
    note right of Chef: Chef ordena y embellece los datos (pprint)
    Chef -> User: Imprime los resultados formateados en pantalla
    note left of Chef: Imprime los 20 documentos y el resumen.
    Chef -> User: Script termina (OK)
end

@enduml