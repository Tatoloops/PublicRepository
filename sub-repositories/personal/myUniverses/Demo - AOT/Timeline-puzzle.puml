@startuml
title Attack on Titan - Timeline Puzzle (Truth vs Reveal)

' =========================
' TRUE HISTORY (LEFT SIDE)
' =========================

package "TRUE HISTORY (Chronological Order)" {

[~2000 Years Ago\nYmir Fritz gains Titan power] as Ymir

[Ymir's power splits into 9 Titans] as NineTitans

[Eldian Empire dominates world] as EldianEmpire

[Marley rebels and wins\nGreat Titan War] as MarleyVictory

[King Fritz retreats to Paradis\nCreates the Walls\n(Vow Renouncing War)] as Walls

[Memory manipulation of Eldians] as MemoryWipe

[Marley uses Titans as weapons] as MarleyControl

[Warriors sent to Paradis\n(Reiner, Bertholdt, Annie)] as WarriorsMission

[Fall of Wall Maria\nStory begins] as Start
}

Ymir --> NineTitans 
NineTitans --> EldianEmpire 
EldianEmpire --> MarleyVictory 
MarleyVictory --> Walls 
Walls --> MemoryWipe 
MemoryWipe --> MarleyControl
MarleyControl --> WarriorsMission 
WarriorsMission --> Start


' =========================
' STORY REVEAL ORDER (RIGHT SIDE)
' =========================

package "STORY (What Audience Learns)" {

[Humanity vs Titans\n(Survival Horror)] as Phase1

[Annie = Titan\nEnemy is human] as Phase2

[Reiner/Bertholdt Reveal] as Phase3

[Basement Reveal\n(Outside World Exists)] as Phase4

[Marley Perspective Introduced] as Phase5

[Eldian History Revealed] as Phase6

[Paths / Ymir Truth] as Phase7

[Eren's True Plan\n(The Rumbling)] as Phase8
}

Phase1 --> Phase2
Phase2 --> Phase3 
Phase3 --> Phase4
Phase4 --> Phase5 
Phase5 --> Phase6 
Phase6 --> Phase7 
Phase7 --> Phase8


' =========================
' CONNECTIONS (REVEAL LINKS)
' =========================

' What each reveal actually connects to in the past

Phase1 .right.> Walls : "Hidden Truth"
Phase2 .right.> WarriorsMission : "Enemy origin"
Phase3 .right.> MarleyControl : "Warrior program"
Phase4 .right.> MarleyVictory : "World history"
Phase5 .right.> MarleyControl
Phase6 .right.> EldianEmpire
Phase7 .right.> Ymir
Phase8 .right.> Ymir


' =========================
' EREN TIME LOOP (CRITICAL)
' =========================

[Future Eren influences the past\n(Paths)] as ErenLoop

ErenLoop --> Ymir : "Origin manipulation"
ErenLoop --> Start : "Guides events"

@enduml